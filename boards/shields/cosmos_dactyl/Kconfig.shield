config SHIELD_COSMOS_DACTYL_LEFT
    bool "CosmoDactyl Left"
    default y if $(shields_list_contains,cosmos_dactyl_r2c_left)
    default y if $(shields_list_contains,cosmos_dactyl_c2r_left)

config SHIELD_COSMOS_DACTYL_RIGHT
    bool "CosmoDactyl Right"
    default y if $(shields_list_contains,cosmos_dactyl_r2c_right)
    default y if $(shields_list_contains,cosmos_dactyl_c2r_right)
