    /*
     * Interim 7x14 grid physical layout. This matches the existing matrix-based
     * keymap so ZMK Studio can build without rewriting the keymap. The visual
     * representation in Studio will be a plain grid rather than the dactyl
     * shape. Replace this with the real dactyl layout above once a 69-position
     * keymap is created.
     */
    layout_0: layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Matrix Grid";
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
