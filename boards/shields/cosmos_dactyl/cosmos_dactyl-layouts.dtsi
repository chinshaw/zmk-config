#include <physical_layouts.dtsi>

/ {
    /*
     * Preserved dactyl physical layout (69 keys). Disabled for now because
     * ZMK Studio requires the keymap to use physical-layout positions, and the
     * current keymap is written for a 7x14 matrix (98 logical positions).
     * Re-enable this and provide a matching 69-position keymap + transform to
     * get the real dactyl shape in ZMK Studio.
     */
    layout_dactyl: layout_dactyl {
        compatible = "zmk,physical-layout";
        status = "disabled";
        display-name = "Dactyl";
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100  333    0       0     0     0>
            , <&key_physical_attrs 100 100 1464    0       0     0     0>
